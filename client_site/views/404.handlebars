<!--
Name: Patrick Sullivan
Date: March 1, 2026
File: 404.handlebars
Overview: This file is my custom 404 page. It comes when a page is not found, and is rendered through main.handlebars when server.js cannot
route to the desired page. 
-->
<div class="error-container">
  <h1 class="error-code">404</h1>
  <h2>Oops! Page Not Found</h2>
  <p>The page you're looking for doesn't exist or has moved.</p>
  <p><strong>{{pageTitle}}</strong></p>
  
  <div class="error-actions">
    <a href="/" class="buttonPrimary">← Back to Home</a>
  </div>
</div>
